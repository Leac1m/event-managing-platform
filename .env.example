# Event Managing Platform - Environment Configuration Template

# Copy this file to `.env.local` and fill in your values

# =============================================================================
# Backend Configuration
# =============================================================================

# Database URL
# - Local development: sqlite.db
# - Docker: /app/data/sqlite.db
# - Remote: postgresql://user:password@host:port/dbname
DATABASE_URL=./sqlite.db

# Upload directory for profile images
# - Local development: ./uploads
# - Docker: /app/uploads (mounted volume)
PROFILE_UPLOAD_DIR=./uploads

# Server port
PORT=3001

# Node environment
# Options: development, staging, production
NODE_ENV=development

# JWT Configuration
# Generate a secure random string for JWT signing
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production

# JWT Token expiry (in hours)
JWT_EXPIRES_IN=24

# =============================================================================
# Frontend Configuration
# =============================================================================

# API base URL (frontend)
# - Development: http://localhost:3001
# - Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:3001

# App environment
VITE_ENV=development

# =============================================================================
# Email Configuration (for future use)
# =============================================================================

# SMTP server settings
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# SMTP_FROM_EMAIL=noreply@eventmanagingplatform.com

# Email verification settings
# VERIFY_EMAIL=true
# EMAIL_VERIFICATION_EXPIRES_IN=24h

# =============================================================================
# Docker Configuration
# =============================================================================

# Database path in container (should match PROFILE_UPLOAD_DIR if using volumes)
# DOCKER_DB_PATH=/app/data/sqlite.db
# DOCKER_UPLOADS_PATH=/app/uploads

# =============================================================================
# Security Settings
# =============================================================================

# CORS origins (comma-separated)
# For development: http://localhost:5173,http://localhost:3000
# For production: https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Allowed file upload types (comma-separated MIME types)
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/webp

# Maximum file size in bytes (default: 524288 = 512KB)
MAX_FILE_SIZE=524288

# =============================================================================
# Logging
# =============================================================================

# Log level
# Options: error, warn, info, debug, trace
LOG_LEVEL=debug

# =============================================================================
# Feature Flags (for future use)
# =============================================================================

# Enable email verification for new registrations
ENABLE_EMAIL_VERIFICATION=false

# Enable social login
ENABLE_SOCIAL_LOGIN=false

# Enable two-factor authentication
ENABLE_TWO_FACTOR_AUTH=false

# =============================================================================
# Third-Party Services (for future integration)
# =============================================================================

# Google OAuth (for social login)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# SendGrid (for email)
# SENDGRID_API_KEY=your_sendgrid_api_key

# AWS S3 (for file storage)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_S3_BUCKET=your_bucket_name
# AWS_REGION=us-east-1

# =============================================================================
# Development Debugging (local development only)
# =============================================================================

# Enable debug mode
DEBUG=false

# Database query logging
DEBUG_QUERIES=false

# Log all HTTP requests
DEBUG_HTTP=false

# =============================================================================
# Notes
# =============================================================================

# 1. Never commit the actual .env or .env.local file to version control
# 2. Keep .env.example in version control as a template
# 3. Generate secure random values for production secrets:
#    - JWT_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 4. For production deployment:
#    - Set NODE_ENV=production
#    - Use strong JWT_SECRET (64+ character random string)
#    - Configure CORS_ORIGINS to your domain only
#    - Enable email verification if using email features
# 5. Docker users: Set DATABASE_URL=/app/data/sqlite.db when using volumes
