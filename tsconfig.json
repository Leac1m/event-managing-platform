{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@backend/*": ["./packages/backend/src/*"],
      "@frontend/*": ["./packages/frontend/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
